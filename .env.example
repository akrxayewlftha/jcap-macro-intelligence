# Copiez ce fichier en .env et remplissez vos clés API
# cp .env.example .env

# Groq — préféré pour la vitesse (Llama 3.3 70B gratuit avec quota généreux)
# Obtenez votre clé sur : https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Anthropic Claude — fallback si Groq indisponible
# Obtenez votre clé sur : https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Répertoire pour le cache des embeddings (accélère les relances)
EMBEDDINGS_CACHE_DIR=data/processed/cache
